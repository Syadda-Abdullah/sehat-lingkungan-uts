<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SehatLingkungan | Sistem Laporan Masyarakat</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body class="bg-slate-50 font-sans">

    <nav class="bg-emerald-600 text-white shadow-lg p-4 sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-bold flex items-center gap-2">
                <i class="fas fa-heart-pulse"></i> SehatLingkungan
            </h1>
            <div class="flex gap-4">
                <button onclick="showTab('laporan')" class="text-sm font-medium hover:text-emerald-200 transition">Laporan</button>
                <button onclick="showTab('dashboard')" class="text-sm font-medium hover:text-emerald-200 transition">Dashboard</button>
            </div>
        </div>
    </nav>

    <div class="container mx-auto px-4 py-8 max-w-5xl">
        
        <div id="tab-laporan" class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            
            <div class="lg:col-span-1">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200">
                    <h2 class="text-xl font-semibold mb-4 text-slate-800 flex items-center gap-2">
                        <i class="fas fa-edit text-emerald-600"></i> Buat Laporan
                    </h2>
                    <form action="/lapor" method="POST" enctype="multipart/form-data" class="space-y-4">
                        <div>
                            <label class="block text-sm font-medium text-slate-600 mb-1">Nama Pelapor</label>
                            <input type="text" name="nama_pelapor" required class="w-full px-4 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none transition-all">
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-600 mb-1">Deskripsi Masalah</label>
                            <textarea name="deskripsi" required rows="3" class="w-full px-4 py-2 rounded-lg border border-slate-300 focus:ring-2 focus:ring-emerald-500 focus:outline-none transition-all"></textarea>
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-slate-600 mb-1">Foto Bukti (S3 Storage)</label>
                            <input type="file" name="foto" required class="w-full text-sm text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100 cursor-pointer">
                        </div>
                        <button type="submit" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 rounded-xl transition-all shadow-md active:scale-95">
                            Kirim Laporan <i class="fas fa-paper-plane ml-1"></i>
                        </button>
                    </form>
                </div>
            </div>

            <div class="lg:col-span-2">
                <h2 class="text-xl font-semibold mb-4 text-slate-800 flex items-center gap-2">
                    <i class="fas fa-list-ul text-emerald-600"></i> Pantauan Laporan Terbaru
                </h2>
                
                <% if (laporan.length === 0) { %>
                    <div class="bg-white p-12 text-center rounded-2xl border-2 border-dashed border-slate-300">
                        <i class="fas fa-folder-open text-4xl text-slate-300 mb-2"></i>
                        <p class="text-slate-500">Belum ada laporan masuk.</p>
                    </div>
                <% } else { %>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <% laporan.forEach(item => { %>
                            <div class="bg-white rounded-2xl overflow-hidden shadow-sm border border-slate-200 hover:shadow-md transition-shadow flex flex-col">
                                <div class="relative group">
                                    <% if (item.foto_url.toLowerCase().endsWith('.pdf')) { %>
                                        <div class="w-full h-48 bg-slate-100 flex flex-col items-center justify-center border-b">
                                            <i class="fas fa-file-pdf text-5xl text-red-500 mb-2"></i>
                                            <span class="text-xs text-slate-500 font-medium">Dokumen PDF</span>
                                        </div>
                                    <% } else { %>
                                        <img src="<%= item.foto_url %>" alt="Laporan" class="w-full h-48 object-cover border-b">
                                    <% } %>
                                    
                                    <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center gap-3">
                                        <a href="<%= item.foto_url %>" target="_blank" class="bg-white p-2 rounded-full text-slate-800 hover:bg-emerald-500 hover:text-white transition-colors shadow-lg">
                                            <i class="fas fa-expand"></i>
                                        </a>
                                        <a href="<%= item.foto_url %>" download class="bg-white p-2 rounded-full text-slate-800 hover:bg-blue-500 hover:text-white transition-colors shadow-lg">
                                            <i class="fas fa-download"></i>
                                        </a>
                                    </div>
                                </div>

                                <div class="p-4 flex-grow">
                                    <div class="flex justify-between items-start mb-2">
                                        <h3 class="font-bold text-slate-800"><%= item.nama_pelapor %></h3>
                                        <span class="text-[10px] text-slate-400 uppercase tracking-widest"><%= new Date(item.tanggal).toLocaleDateString('id-ID') %></span>
                                    </div>
                                    <p class="text-slate-600 text-sm leading-relaxed mb-4"><%= item.deskripsi %></p>
                                    
                                    <div class="flex gap-4 mt-2 pt-2 border-t border-slate-100">
                                        <a href="<%= item.foto_url %>" target="_blank" class="text-xs font-semibold text-emerald-600 hover:underline">
                                            <i class="fas fa-external-link-alt mr-1"></i> Buka
                                        </a>
                                        <button onclick="editLaporan('<%= item.id %>', '<%= item.deskripsi %>')" class="text-xs font-semibold text-blue-600 hover:text-blue-700">
                                            <i class="fas fa-edit"></i> Edit
                                        </button>
                                        <button onclick="hapusLaporan('<%= item.id %>')" class="text-xs font-semibold text-red-600 hover:text-red-700">
                                            <i class="fas fa-trash"></i> Hapus
                                        </button>
                                    </div>
                                </div>
                            </div>
                        <% }) %>
                    </div>
                <% } %>
            </div>
        </div>

        <div id="tab-dashboard" class="hidden animate-fadeIn">
            <h2 class="text-2xl font-bold mb-6 text-slate-800 flex items-center gap-2">
                <i class="fas fa-chart-pie text-emerald-600"></i> Statistik Real-time
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 text-center">
                    <p class="text-slate-500 text-xs uppercase tracking-widest font-bold">Total Laporan</p>
                    <h3 class="text-4xl font-black text-emerald-600 mt-2"><%= stats.total %></h3>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 text-center">
                    <p class="text-slate-500 text-xs uppercase tracking-widest font-bold">File PDF</p>
                    <h3 class="text-4xl font-black text-red-500 mt-2"><%= stats.pdf_count %></h3>
                </div>
                <div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-200 text-center">
                    <p class="text-slate-500 text-xs uppercase tracking-widest font-bold">File Gambar</p>
                    <h3 class="text-4xl font-black text-blue-500 mt-2"><%= stats.img_count %></h3>
                </div>
            </div>

            <div class="bg-white p-8 rounded-3xl shadow-sm border border-slate-200 flex flex-col items-center">
                <h3 class="text-lg font-bold mb-6 text-slate-700">Persentase Tipe File</h3>
                <div style="width: 300px; height: 300px;">
                    <canvas id="ctxChart"></canvas>
                </div>
            </div>
        </div>

    </div>

    <footer class="text-center py-10 text-slate-400 text-xs">
        &copy; 2026 SehatLingkungan - Syadda Abdullah (152022037) <br>
        Powered by AWS EC2, RDS, and S3
    </footer>

    <script>
        function editLaporan(id, deskripsiLama) {
            const deskripsiBaru = prompt("Edit Deskripsi Laporan:", deskripsiLama);
            if (deskripsiBaru !== null && deskripsiBaru !== deskripsiLama) {
                fetch(`/edit/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ deskripsi: deskripsiBaru })
                }).then(() => window.location.reload());
            }
        }

        function hapusLaporan(id) {
            if (confirm("Apakah Anda yakin ingin menghapus laporan ini?")) {
                fetch(`/hapus/${id}`, { method: 'POST' })
                .then(() => window.location.reload());
            }
        }

        function showTab(tabName) {
                const laporanContent = document.getElementById('tab-laporan');
                const dashboardContent = document.getElementById('tab-dashboard');
                
                if (tabName === 'dashboard') {
                    laporanContent.classList.add('hidden');
                    dashboardContent.classList.remove('hidden');
                } else {
                    laporanContent.classList.remove('hidden');
                    dashboardContent.classList.add('hidden');
                }
            }

            // Inisialisasi Grafik - Pastikan menggunakan tag EJS yang bersih
            const imgCount = parseInt("<%= stats.img_count %>") || 0;
            const pdfCount = parseInt("<%= stats.pdf_count %>") || 0;

            const ctx = document.getElementById('ctxChart').getContext('2d');
            new Chart(ctx, {
                type: 'doughnut',
                data: {
                    labels: ['Gambar', 'PDF'],
                    datasets: [{
                        data: [imgCount, pdfCount],
                        backgroundColor: ['#10b981', '#ef4444'],
                        hoverOffset: 10,
                        borderWidth: 0
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });        
    </script>
</body>
</html>